<div class="hero-banner">
  {% if section.settings.image %}
    <div class="hero-image">
      <img src="{{ section.settings.image | img_url: '1600x800', crop: 'center' }}" alt="{{ section.settings.title }}">
    </div>
  {% endif %}
  
  <div class="hero-content">
    <h1>{{ section.settings.title }}</h1>
    <p>{{ section.settings.text }}</p>
    
    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="btn-hero">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</div>

<style>
.hero-banner {
  position: relative;
  height: 70vh;
  min-height: 500px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.hero-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(0.7);
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
  color: white;
  max-width: 800px;
  padding: 2rem;
}

.hero-content h1 {
  font-family: 'Cormorant Garamond', serif;
  font-size: 4rem;
  margin-bottom: 1.5rem;
  letter-spacing: 2px;
  text-shadow: 0 2px 10px rgba(0,0,0,0.3);
}

.hero-content p {
  font-size: 1.3rem;
  margin-bottom: 2rem;
  line-height: 1.6;
  text-shadow: 0 1px 5px rgba(0,0,0,0.3);
}

.btn-hero {
  display: inline-block;
  padding: 1rem 3rem;
  background: #C99114;
  color: white;
  font-size: 0.9rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: all 0.3s ease;
  border: 2px solid #C99114;
}

.btn-hero:hover {
  background: white;
  color: #C99114;
}

@media (max-width: 768px) {
  .hero-banner {
    height: 60vh;
    min-height: 400px;
  }
  
  .hero-content h1 {
    font-size: 2.5rem;
  }
  
  .hero-content p {
    font-size: 1.1rem;
  }
}
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Azalea Novias"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texto",
      "default": "Vistiendo tus momentos especiales desde hace 36 años"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Descubre Nuestras Colecciones"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del botón",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
